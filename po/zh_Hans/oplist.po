msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Config"
msgstr "配置"

msgid "Main"
msgstr "主要"

msgid "Advanced"
msgstr "高级"

msgid "Logs"
msgstr "日志"

msgid "RUNNING"
msgstr "运行中"

msgid "NOT RUNNING"
msgstr "未运行"

msgid "LuCI support for OpenList"
msgstr "OpenList的LuCI支持"

msgid "The initial admin password is randomly generated. Check the Logs page after enabling the service for the first time."
msgstr "初始管理员密码会随机生成。首次启用服务后，请前往日志页面查看。"

msgid "Enable Service"
msgstr "启用服务"

msgid "Listen Address"
msgstr "监听地址"

msgid "Address on which OpenList listens. Use 0.0.0.0 or :: to listen on all network interfaces."
msgstr "OpenList 的监听地址。使用 0.0.0.0 或 :: 监听所有网络接口。"

msgid "HTTP Listen Port"
msgstr "HTTP监听端口"

msgid "Site URL"
msgstr "站点 URL"

msgid "This option is intended for deployments using a CDN and updates the `site_url` field in the configuration file. Leave it empty if you are unsure what it does."
msgstr "此选项适用于启用 CDN 的场景，并会修改配置文件中的 `site_url` 字段。如果你不清楚它的用途，请留空。"

msgid "Login Expiration (hours)"
msgstr "登录有效期（小时）"

msgid "Max Connections"
msgstr "最大连接数"

msgid "Set to 0 for unlimited."
msgstr "设置为 0 表示不限制。"

msgid "Max Concurrency"
msgstr "最大并发数"

msgid "Delayed Start (seconds)"
msgstr "延迟启动（秒）"

msgid "Enable TLS"
msgstr "启用 TLS"

msgid "HTTPS Listen Port"
msgstr "HTTPS监听端口"

msgid "Certificate Path"
msgstr "证书文件路径"

msgid "Path to your .crt / .cer file"
msgstr ".crt 或 .cer 文件路径"

msgid "Private Key Path"
msgstr "私钥文件路径"

msgid "Path to your .key / .pem file"
msgstr ".key 或 .pem 文件路径"

msgid "Enable HTTP3"
msgstr "启用 HTTP/3"

msgid "Enable Logging"
msgstr "启用日志记录"

msgid "Max log size (MB)"
msgstr "最大日志大小（单位：MB）"

msgid "Max Log Backups"
msgstr "最大日志备份数量"

msgid "Max Log Age (days)"
msgstr "日志最长保留时间（天）"

msgid "Compress Rotated Logs"
msgstr "压缩轮换日志"

msgid "Compress old log files after rotation to save storage space."
msgstr "日志轮换后压缩旧日志文件，以节省存储空间。"

msgid "Enable Log Filter"
msgstr "启用日志过滤"

msgid "Filters access logs generated by health checks, HEAD requests, and common WebDAV requests. It does not block these requests."
msgstr "过滤健康检查、HEAD 和常见 WebDAV 请求产生的访问日志，但不会阻止这些请求。"

msgid "Cache Directory"
msgstr "缓存目录"

msgid "Directory for temporary files during upload."
msgstr "上传文件临时缓存目录"

msgid "Enable S3 Server"
msgstr "启用 S3 服务"

msgid "S3 Listen Port"
msgstr "S3 监听端口"

msgid "Enable S3 TLS"
msgstr "启用 S3 TLS"

msgid "Enable FTP Server"
msgstr "启用 FTP 服务"

msgid "FTP Listen Address"
msgstr "FTP 监听地址"

msgid "Enable SFTP Server"
msgstr "启用 SFTP 服务"

msgid "SFTP Listen Address"
msgstr "SFTP 监听地址"

msgid "Enable MCP Server"
msgstr "启用 MCP 服务"

msgid "Collecting data..."
msgstr "收集数据中..."

msgid "Log is empty."
msgstr "日志是空的"

msgid "Log file does not exist."
msgstr "日志文件不存在"

msgid "Unknown error: %s"
msgstr "未知错误：%s"

msgid "This will permanently erase the current log file. Continue?"
msgstr "此操作将永久删除当前日志文件，你要继续吗？"

msgid "Cancel"
msgstr "取消"

msgid "Clear log"
msgstr "删除日志"

msgid "Failed to clear log: %s"
msgstr "删除日志失败：%s"

msgid "Refresh every 5 seconds."
msgstr "每5秒刷新一次"

msgid "Pause auto-refresh"
msgstr "暂停刷新"

msgid "Resume auto-refresh"
msgstr "继续刷新"

msgid "Refresh"
msgstr "刷新一下"

msgid "Shows the last 1000 lines and auto-refreshes every 5 seconds."
msgstr "显示最后 1000 行日志，每 5 秒自动刷新一次。"
