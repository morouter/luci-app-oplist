msgid "Config"
msgstr "配置"

msgid "Logs"
msgstr "日志"

msgid "RUNNING"
msgstr "运行中"

msgid "NOT RUNNING"
msgstr "未运行"

msgid "LuCI support for OpenList"
msgstr "OpenList的LuCI支持"

msgid "Default username/password: admin/password"
msgstr "默认用户名/密码：admin/password"

msgid "If you need to modify options that are not available, please edit the /etc/openlist/config.json file."
msgstr "如果你需要修改我们没有的选项，请编辑/etc/openlist/config.json文件。"

msgid "Enable Service"
msgstr "启用服务"

msgid "HTTP Listen Port"
msgstr "HTTP监听端口"

msgid "Enable TLS"
msgstr "启用 TLS"

msgid "HTTPS Listen Port"
msgstr "HTTPS监听端口"

msgid "Certificate Path"
msgstr "证书文件路径"

msgid "Path to your .crt / .cer file"
msgstr ".crt 或 .cer 文件路径"

msgid "Private Key Path"
msgstr "私钥文件路径"

msgid "Path to your .key / .pem file"
msgstr ".key 或 .pem 文件路径"

msgid "Enable HTTP3"
msgstr "启用 HTTP/3"

msgid "Enable Logging"
msgstr "启用日志记录"

msgid "Max log size (MB)"
msgstr "最大日志大小（单位：MB）"

msgid "Cache Directory"
msgstr "缓存目录"

msgid "Directory for temporary files during upload."
msgstr "上传文件临时缓存目录"

msgid "Collecting data..."
msgstr "收集数据中..."

msgid "Log is empty."
msgstr "日志是空的"

msgid "Log file does not exist."
msgstr "日志文件不存在"

msgid "Unknown error: %s"
msgstr "未知错误："

msgid "This will permanently erase the current log file. Continue?"
msgstr "此操作将永久删除当前日志文件，你要继续吗？"

msgid "Cancel"
msgstr "取消"

msgid "Clear log"
msgstr "删除日志"

msgid "Failed to clear log: %s"
msgstr "删除日志失败：%s"

msgid "Refresh every 5 seconds."
msgstr "每5秒刷新一次"
