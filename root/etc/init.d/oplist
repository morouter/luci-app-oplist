#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

BINARY="/usr/bin/openlist"
CONF_DIR="/etc/openlist"
CONF_FILE="$CONF_DIR/config.json"
CONFIG_UPDATER="/usr/share/oplist/update-config.uc"

update_config() {
    local tmp_file="$CONF_FILE.tmp.$$"

    if ! ucode "$CONFIG_UPDATER" "$CONF_FILE" >"$tmp_file"; then
        logger -t oplist "failed to update $CONF_FILE"
        rm -f "$tmp_file"
        return 1
    fi

    chmod 600 "$tmp_file" || {
        rm -f "$tmp_file"
        return 1
    }
    mv -f "$tmp_file" "$CONF_FILE"
}

start_service() {
    config_load oplist
    local enabled
    config_get_bool enabled main enabled 0
    [ "$enabled" -eq 0 ] && return

    mkdir -p "$CONF_DIR"

    if [ ! -f "$CONF_FILE" ]; then
        "$BINARY" server --data "$CONF_DIR" >/dev/null 2>&1 &
        local pid=$!
        local wait=0
        while [ ! -f "$CONF_FILE" ] && [ $wait -lt 10 ]; do
            sleep 1
            wait=$((wait + 1))
        done
        kill "$pid" 2>/dev/null
        local kill_wait=0
        while kill -0 "$pid" 2>/dev/null && [ $kill_wait -lt 10 ]; do
            sleep 1
            kill_wait=$((kill_wait + 1))
        done
        # Escalate if it ignored SIGTERM, then wait for reaping either way.
        kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
        wait "$pid" 2>/dev/null

        if [ ! -f "$CONF_FILE" ]; then
            logger -t oplist "bootstrap failed: $CONF_FILE was not created"
            return 1
        fi
    fi

    update_config || return 1

    procd_open_instance "instance1"
    procd_set_param command "$BINARY" server --data "$CONF_DIR"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "oplist"
}

reload_service() {
    stop
    start
}
