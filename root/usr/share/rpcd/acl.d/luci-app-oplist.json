{
  "luci-app-oplist": {
    "description": "ACL for luci-app-oplist",
    "read": {
      "file": {
        "/etc/openlist/log/log.log": ["read"]
      },
      "uci": ["oplist"],
      "ubus": {
        "service": ["list"],
        "uci": ["get"]
      }
    },
    "write": {
      "file": {
        "/etc/openlist/log/log.log": ["write"]
      },
      "uci": ["oplist"],
      "ubus": {
        "uci": ["set", "commit", "apply", "confirm"]
      }
    }
  }
}
